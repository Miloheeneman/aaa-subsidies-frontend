# Backend base URL. The /api/v1 suffix is optional — the axios client
# appends it automatically if it's not present. Both of these work:
#   VITE_API_URL=http://localhost:8000
#   VITE_API_URL=http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000

# Optioneel: contact op klantportal (defaults: subsidies@… / 070-nummer)
# VITE_AAA_LEX_CONTACT_EMAIL=subsidies@aaa-lexoffices.nl
# VITE_AAA_LEX_CONTACT_PHONE=+31 (0)70 753 00 88
